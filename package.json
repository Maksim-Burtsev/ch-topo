{
  "name": "chtopo",
  "version": "0.0.0",
  "description": "Interactive schema topology viewer and impact analyzer for ClickHouse.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Maksim-Burtsev/ch-topo.git"
  },
  "bugs": {
    "url": "https://github.com/Maksim-Burtsev/ch-topo/issues"
  },
  "homepage": "https://github.com/Maksim-Burtsev/ch-topo#readme",
  "keywords": [
    "clickhouse",
    "schema",
    "dependency-graph",
    "impact-analysis",
    "database",
    "sql"
  ],
  "engines": {
    "node": "^22.22.1 || >=24.0.0"
  },
  "type": "module",
  "bin": {
    "chtopo": "./dist-cli/chtopo.js"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run cli:build && tsc -b && vite build",
    "cli:build": "vite build --config vite.cli.config.ts",
    "api:build": "tsc -p tsconfig.api.json",
    "api:start": "node dist-api/main.js",
    "lint": "eslint src/ api/ tests/ playwright.config.ts vite.config.ts vite.cli.config.ts --max-warnings 0",
    "lint:fix": "eslint src/ api/ --fix",
    "format": "prettier --write src/ api/ tests/ playwright.config.ts vite.config.ts vite.cli.config.ts eslint.config.js",
    "format:check": "prettier --check src/ api/ tests/ playwright.config.ts vite.config.ts vite.cli.config.ts eslint.config.js",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:integration": "node scripts/run-clickhouse-integration.mjs",
    "test:integration:run": "VITE_CHTOPO_INTEGRATION=1 vitest run src/lib/integration/clickhouse.integration.test.ts",
    "test:smoke": "playwright test",
    "test:watch": "vitest",
    "audit": "npm audit --audit-level=moderate",
    "check": "npm run typecheck && npm run lint && npm run format:check",
    "verify": "npm run check && npm run audit && npm run test && npm run build",
    "preview": "vite preview",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "api/**/*.ts": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "src/**/*.{css,json}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/vite": "^4.3.0",
    "@xyflow/react": "^12.11.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "^7.15.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.2.2",
    "zustand": "^5.0.13"
  },
  "overrides": {
    "monaco-editor": {
      "dompurify": "3.4.8"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.12.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.8"
  }
}
